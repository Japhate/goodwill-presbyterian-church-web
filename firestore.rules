rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{userId} {
      allow get: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'first_name', 'last_name', 'email', 'photo_url', 'updated_date'
        ])
        && (
          !('first_name' in request.resource.data)
          || request.resource.data.first_name is string
          && request.resource.data.first_name.size() <= 80
        )
        && (
          !('last_name' in request.resource.data)
          || request.resource.data.last_name is string
          && request.resource.data.last_name.size() <= 80
        )
        && (
          !('email' in request.resource.data)
          || request.resource.data.email is string
          && request.resource.data.email.size() <= 320
        )
        && (
          !('photo_url' in request.resource.data)
          || request.resource.data.photo_url is string
          && request.resource.data.photo_url.size() <= 2000
        );
      allow create, delete: if false;
    }

    match /HeroSlide/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /Bulletins/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /AnnouncementsEvents/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /WorshipEvent/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /Sermons/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /Banner/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /HomeBannerMessages/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /SitePopups/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /EmailTemplates/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /NewsletterBroadcasts/{documentId} {
      allow read, write: if isAdmin();
    }

    match /PrayerRequests/{documentId} {
      allow read, update, delete: if isAdmin();
      allow create: if request.resource.data.keys().hasOnly([
          'name', 'email', 'prayer_request', 'is_public', 'status', 'created_date'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.prayer_request is string
        && request.resource.data.prayer_request.size() > 0
        && request.resource.data.prayer_request.size() <= 5000
        && (
          !('email' in request.resource.data)
          || request.resource.data.email == null
          || (request.resource.data.email is string && request.resource.data.email.size() <= 320)
        )
        && request.resource.data.status == 'pending'
        && request.resource.data.is_public is bool;
    }

    match /NewsletterSubscriptions/{documentId} {
      allow read, delete: if isAdmin();
      allow create: if request.resource.data.keys().hasOnly([
          'first_name', 'last_name', 'email', 'email_key', 'unsubscribe_token', 'status', 'created_date'
        ])
        && request.resource.data.first_name is string
        && request.resource.data.first_name.size() > 0
        && request.resource.data.first_name.size() <= 80
        && request.resource.data.last_name is string
        && request.resource.data.last_name.size() > 0
        && request.resource.data.last_name.size() <= 80
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() <= 320
        && request.resource.data.email_key == documentId
        && request.resource.data.email_key is string
        && request.resource.data.unsubscribe_token is string
        && request.resource.data.unsubscribe_token.size() >= 24
        && request.resource.data.status == 'active';
      allow update: if isAdmin()
        || (
          resource.data.email_key == documentId
          && request.resource.data.email == resource.data.email
          && request.resource.data.email_key == resource.data.email_key
          && request.resource.data.unsubscribe_token == resource.data.unsubscribe_token
          && request.resource.data.unsubscribe_token_confirm == resource.data.unsubscribe_token
          && request.resource.data.status == 'unsubscribed'
          && request.resource.data.unsubscribed_date is string
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'status', 'unsubscribed_date', 'updated_date', 'unsubscribe_token_confirm'
          ])
        )
        || (
          resource.data.status == 'unsubscribed'
          && request.resource.data.first_name is string
          && request.resource.data.first_name.size() > 0
          && request.resource.data.first_name.size() <= 80
          && request.resource.data.last_name is string
          && request.resource.data.last_name.size() > 0
          && request.resource.data.last_name.size() <= 80
          && request.resource.data.email == resource.data.email
          && request.resource.data.email_key == resource.data.email_key
          && request.resource.data.email_key == documentId
          && request.resource.data.unsubscribe_token is string
          && request.resource.data.unsubscribe_token.size() >= 24
          && request.resource.data.status == 'active'
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'first_name', 'last_name', 'unsubscribe_token', 'status', 'created_date', 'unsubscribed_date', 'updated_date', 'unsubscribe_token_confirm'
          ])
        );
    }
  }
}
