rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{userId} {
      allow get: if request.auth != null && request.auth.uid == userId;
      allow list, write: if false;
    }

    match /HeroSlide/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /Bulletins/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /AnnouncementsEvents/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /WorshipEvent/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /Sermons/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /Banner/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /HomeBannerMessages/{documentId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /PrayerRequests/{documentId} {
      allow read, update, delete: if isAdmin();
      allow create: if request.resource.data.keys().hasOnly([
          'name', 'email', 'prayer_request', 'is_public', 'status', 'created_date'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 120
        && request.resource.data.prayer_request is string
        && request.resource.data.prayer_request.size() > 0
        && request.resource.data.prayer_request.size() <= 5000
        && (
          !('email' in request.resource.data)
          || request.resource.data.email == null
          || (request.resource.data.email is string && request.resource.data.email.size() <= 320)
        )
        && request.resource.data.status == 'pending'
        && request.resource.data.is_public is bool;
    }

    match /NewsletterSubscriptions/{documentId} {
      allow read, update, delete: if isAdmin();
      allow create: if request.resource.data.keys().hasOnly(['email', 'created_date'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() <= 320;
    }
  }
}
