rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    match /homepage-hero-images/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin()
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if isAdmin();
    }

    match /bulletins-pdfs/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin()
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType == 'application/pdf';
      allow delete: if isAdmin();
    }

    match /bulletin-thumbnails/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin()
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if isAdmin();
    }

    match /announcement-images/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin()
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if isAdmin();
    }

    match /newsletter-attachments/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin()
        && request.resource.size < 8 * 1024 * 1024;
      allow delete: if isAdmin();
    }

    match /admin-profile-images/{allPaths=**} {
      allow read: if true;
      allow create, update: if isAdmin()
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if isAdmin();
    }
  }
}
